# ─────────────────────────────────────────────────────────────
# Aggrimart Backend — Environment Variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=4000
APP_NAME=Aggrimart
# Comma separated list of allowed origins for CORS (mobile app dev tools / web admin)
CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# Database (Azure PostgreSQL Flexible Server in production)
# Local example: postgresql://postgres:postgres@localhost:5432/aggrimart?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aggrimart?schema=public"

# JWT — generate strong secrets, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_TTL=900            # access token lifetime in seconds (15 min)
JWT_REFRESH_TTL=2592000       # refresh token lifetime in seconds (30 days)
JWT_ISSUER=aggrimart
JWT_AUDIENCE=aggrimart-mobile

# OTP
OTP_TTL=300                   # OTP validity window in seconds (5 min)
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN=30        # seconds between OTP requests for the same number
# In development OTPs are returned in the API response + logged. Set false in prod.
OTP_DEV_MODE=true

# SMS provider (production OTP delivery). Leave blank to use dev/log transport.
SMS_PROVIDER=                 # e.g. "twilio" | "msg91" | "" (dev)
SMS_API_KEY=
SMS_SENDER_ID=

# Rate limiting (token bucket per IP / per identity)
RATE_LIMIT_WINDOW=60          # seconds
RATE_LIMIT_MAX=120            # requests per window for general endpoints
RATE_LIMIT_AUTH_MAX=10        # stricter limit for auth endpoints

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_ACCOUNT_NAME=""
AZURE_STORAGE_CONTAINER=product-images
AZURE_BLOB_PUBLIC_BASE_URL=   # e.g. https://<account>.blob.core.windows.net/product-images

# Logging
LOG_LEVEL=info                # trace|debug|info|warn|error
