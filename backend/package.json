{
  "name": "aggrimart-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Natural greenkart - Grocery, Fruits & Vegetables Delivery Platform API (Next.js 15 + Prisma + MySQL)",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate && next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.27.0",
    "@prisma/client": "^6.3.1",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "15.1.6",
    "pino": "^9.6.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.8",
    "eslint": "^9.20.0",
    "eslint-config-next": "15.1.6",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
